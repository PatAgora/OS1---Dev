# Copy to .env and fill values
FLASK_SECRET_KEY=change-this
DATABASE_URL=sqlite:///ats.db

# ---- Google Gemini AI (optional) ----
# Set this to enable AI candidate scoring and CV summarisation.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Signable (signable.co.uk) — get API key from Settings > API in your Signable dashboard
SIGNABLE_API_KEY=your_signable_api_key
SIGNABLE_BASE_URL=https://api.signable.co.uk/v1
SIGNABLE_WEBHOOK_SECRET=optional_webhook_signing_secret
SIGNABLE_TEMPLATE_FINGERPRINT=your_template_fingerprint_from_signable_dashboard

# Req-005 — Associate declaration form Signable integration.
# COST GUARDRAIL: leave SIGNABLE_LIVE_CALLS=false (or unset) during development and
# testing. While false, the declaration handler logs what it would have sent and
# stores a "stub-<uuid>" envelope ID instead of touching the Signable API. Flip to
# "true" only after the user has approved going live and the placeholder values
# below have been confirmed (each one is sent in real envelopes).
SIGNABLE_LIVE_CALLS=false
SIGNABLE_DECLARATION_TEMPLATE_ID=
SIGNABLE_DECLARATION_SIGNER_ROLE=Associate

# Verifile pre-employment screening (verifile.co.uk) — v1 API
VERIFILE_BASE_URL=https://api.verifile.co.uk/int/api/v1
VERIFILE_APIM_KEY=your_apim_subscription_key
VERIFILE_USER_ID=your_verifile_user_id
VERIFILE_SUBSIDIARY_ORG_ID=your_subsidiary_organisation_id
VERIFILE_WEBHOOK_SECRET=optional_webhook_signing_secret
# DBS level: Basic, Standard, or Enhanced (depends on client's Verifile package)
VERIFILE_DBS_LEVEL=Basic

# SMTP for onboarding emails & calendar invites
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM="Talent Ops <talent@example.com>"

# Req 50 — compliance@ is used for vetting / reference / chase emails.
COMPLIANCE_FROM_EMAIL=compliance@optimussolutions.co.uk

# Req 53 — finance@ is used for invoice emails. Mailbox is live; M365 SendAs
# permission must be granted on the service principal for this to work.
FINANCE_FROM_EMAIL=finance@optimussolutions.co.uk

# Calendar invite defaults
INTERVIEWER_EMAIL=interviewer@example.com
TIMEZONE=Europe/London

# Microsoft 365 OAuth2 (for sending email as associates@optimussolutions.co.uk
# AND for creating Outlook calendar / Teams meeting invites via Graph).
# All three values come from the Azure AD app registration.
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# Microsoft Graph Teams calendar integration (Req 8 follow-up).
# Leave M365_GRAPH_ENABLED=0 until the Azure admin grants the OS1 app
# Calendars.ReadWrite + OnlineMeetings.ReadWrite.All Application
# permissions and clicks "Grant admin consent". Flip to 1 to start
# creating real Outlook/Teams meeting invites; until then OS1 falls
# back to the legacy .ics-attachment email path automatically.
M365_GRAPH_ENABLED=0
M365_GRAPH_TIMEZONE=Europe/London

# App base URL (public for webhooks & candidate links)
APP_BASE_URL=http://127.0.0.1:5000
