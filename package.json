    "test:associate": "npx playwright test tests/associate/",
    "test:ai": "npx playwright test --grep @ai",
    "test:perf": "npx playwright test --grep @perf",
    "test:a11y": "npx playwright test --grep @a11y",
    "test:deep": "npx playwright test tests/staff/deep/",
    "test:firefox": "npx playwright test --project=firefox --no-deps",
    "test:webkit": "npx playwright test --project=webkit --no-deps",
    "test:cross-browser": "npx playwright test --project=firefox --project=webkit --no-deps",
    "test:report": "npx playwright show-report"
  },
